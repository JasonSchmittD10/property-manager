{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/", "destination": "/admin/index.html" },
    { "source": "/((?!admin|assets|photos|documents|fonts|images|docs|favicon\\.ico|.*\\..*).*)", "destination": "/" }
  ]
}
